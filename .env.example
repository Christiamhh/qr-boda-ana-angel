# ─── Cloudflare R2 (almacenamiento de fotos y videos) ───────────────
# Si estas variables faltan, la app usa almacenamiento LOCAL en disco (.data/)
# solo para desarrollo. En produccion (Vercel) deben estar presentes.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=boda-ana-angel
# URL publica/endpoint S3 de R2: https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=

# ─── Supabase (metadatos + uso unico) ───────────────────────────────
# Si faltan, la app usa una base local en .data/db.json (solo desarrollo).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Galeria privada de los novios ──────────────────────────────────
# Contrasena para que Ana & Angel entren a /galeria
GALLERY_PASSWORD=AnaYAngel2026
# Secreto para firmar la cookie de sesion de la galeria
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio

# ─── General ────────────────────────────────────────────────────────
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
